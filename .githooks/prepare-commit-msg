#!/bin/sh
# Strip Cursor attribution trailers injected by the Agent runtime.
if [ -f "$1" ]; then
  sed -i.bak '/cursoragent@cursor\.com/d' "$1" 2>/dev/null || sed -i '' '/cursoragent@cursor\.com/d' "$1"
  sed -i.bak '/Co-authored-by: Cursor/d' "$1" 2>/dev/null || sed -i '' '/Co-authored-by: Cursor/d' "$1"
  sed -i.bak '/Made-with: Cursor/d' "$1" 2>/dev/null || sed -i '' '/Made-with: Cursor/d' "$1"
  rm -f "$1.bak"
fi
