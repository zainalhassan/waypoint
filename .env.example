# Database (Docker Compose default)
DATABASE_URL=postgresql://waypoint:waypoint@db:5432/waypoint

# When running app on host against Docker DB only:
# DATABASE_URL=postgresql://waypoint:waypoint@localhost:5432/waypoint

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Public URL of the app (no trailing slash)
AUTH_URL=http://localhost:3000
