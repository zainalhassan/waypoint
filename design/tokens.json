{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Stack-agnostic design tokens for Waypoint. Sync with Figma Variables. Import into any stack via CSS, SCSS, or Style Dictionary.",
  "color": {
    "brand": {
      "primary": { "$value": "#1e4d5c", "$type": "color", "$description": "Waypoint teal — nav, primary actions" },
      "primary-foreground": { "$value": "#f8fafc", "$type": "color" },
      "accent": { "$value": "#2dd4bf", "$type": "color", "$description": "Milestone highlight" }
    },
    "semantic": {
      "success": { "$value": "#22c55e", "$type": "color" },
      "warning": { "$value": "#f59e0b", "$type": "color" },
      "destructive": { "$value": "#ef4444", "$type": "color" },
      "muted": { "$value": "#64748b", "$type": "color" }
    },
    "surface": {
      "background": { "$value": "#ffffff", "$type": "color" },
      "foreground": { "$value": "#0f172a", "$type": "color" },
      "card": { "$value": "#ffffff", "$type": "color" },
      "border": { "$value": "#e2e8f0", "$type": "color" }
    },
    "stage": {
      "applied": { "$value": "#3b82f6", "$type": "color" },
      "screening": { "$value": "#8b5cf6", "$type": "color" },
      "interview": { "$value": "#06b6d4", "$type": "color" },
      "offer": { "$value": "#22c55e", "$type": "color" },
      "rejected": { "$value": "#ef4444", "$type": "color" }
    }
  },
  "spacing": {
    "xs": { "$value": "4px", "$type": "dimension" },
    "sm": { "$value": "8px", "$type": "dimension" },
    "md": { "$value": "16px", "$type": "dimension" },
    "lg": { "$value": "24px", "$type": "dimension" },
    "xl": { "$value": "32px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "6px", "$type": "dimension" },
    "md": { "$value": "10px", "$type": "dimension" },
    "lg": { "$value": "14px", "$type": "dimension" }
  },
  "typography": {
    "font-family": {
      "sans": { "$value": "Geist, system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "Geist Mono, ui-monospace, monospace", "$type": "fontFamily" }
    },
    "font-size": {
      "xs": { "$value": "12px", "$type": "dimension" },
      "sm": { "$value": "14px", "$type": "dimension" },
      "base": { "$value": "16px", "$type": "dimension" },
      "lg": { "$value": "18px", "$type": "dimension" },
      "xl": { "$value": "24px", "$type": "dimension" },
      "2xl": { "$value": "30px", "$type": "dimension" }
    }
  }
}
